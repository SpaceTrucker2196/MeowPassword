          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タップすると隠しメッセージが表示されます。上部のパネルに現れます。"
          }
        }
      }
    },
    "Embedded! Ready to share.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eingebettet! Bereit zum Teilen."
          }
        },
