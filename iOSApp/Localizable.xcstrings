    "Nothing to paste — copy a MeowGram image first.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nichts zum Einfügen – kopiere zuerst ein MeowGram-Bild."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing to paste — copy a MeowGram image first."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien à coller — copiez d'abord une image MeowGram."
          }
        },
        "ja": {
