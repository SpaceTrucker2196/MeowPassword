    "WELCOME!": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "WILLKOMMEN!"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "WELCOME!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
