# MeowPassword CI / release automation.
#
# The Xcode project is generated from project.yml by XcodeGen and is gitignored,
# so every lane regenerates it first (ensure_project). iOS and macOS ship under
# one App Store Connect record (io.river.MeowPassword).
#
# Lanes
# -----
#   ios tests      Run the iOS unit tests (compose/decode round-trip) on a sim.
#   ios beta       Build + upload the iOS app to TestFlight.
#   ios release    Build + upload the iOS app to App Store review.
#   mac tests      Run the shared library + core tests via SwiftPM.
#   mac beta       Build + upload the macOS app to TestFlight.
#
# App Store Connect auth (beta/release only) — API key, via env:
#   APP_STORE_CONNECT_API_KEY_KEY_ID        10-char key id (required)
#   APP_STORE_CONNECT_API_KEY_ISSUER_ID     issuer UUID (defaults to river.io)
#   APP_STORE_CONNECT_API_KEY_KEY_FILEPATH  path to AuthKey_<id>.p8, or the lane
#                                           probes the standard dirs; on CI set
#   APP_STORE_CONNECT_API_KEY_KEY           the .p8 contents (base64 or raw)

require "fileutils"

APP_ID            = "io.river.meowpassword"
DEFAULT_KEY_ID    = "H3U2MJCD77"                            # river.io ASC API key (shared with clientAPT)
DEFAULT_ISSUER_ID = "69a6de84-cb86-47e3-e053-5b8c7c11a4d1" # river.io ASC account
DEV_TEAM          = ENV.fetch("DEVELOPMENT_TEAM", "U3Z59VXPUB")
IOS_SCHEME        = "MeowPassword"
MAC_SCHEME        = "MeowPasswordMac"
PROJECT           = "MeowPassword.xcodeproj"
KEY_SEARCH_DIRS   = ["~/.appstoreconnect/private_keys", "~/.private_keys", "~/Downloads"].freeze

# Regenerate the gitignored Xcode project from project.yml.
def ensure_project
  sh("command -v xcodegen >/dev/null 2>&1 || brew install xcodegen")
  Dir.chdir("..") { sh("xcodegen generate") }
end

def locate_key_file(key_id)
  KEY_SEARCH_DIRS.map { |d| File.expand_path("#{d}/AuthKey_#{key_id}.p8") }.find { |p| File.exist?(p) }
end

def asc_api_key
  # Defaults to the shared river.io key (H3U2MJCD77), auto-located from the
  # standard dirs — same setup clientAPT uses, so no env vars are needed
  # locally. CI overrides via APP_STORE_CONNECT_API_KEY_* env vars.
  key_id    = ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID", DEFAULT_KEY_ID)
  issuer_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID", DEFAULT_ISSUER_ID)

  # set_spaceship_token so username-less actions (produce/pilot/deliver) also
  # authenticate with the key.
  if (content = ENV["APP_STORE_CONNECT_API_KEY_KEY"]) && !content.empty?
    # Accept either the raw .p8 (PEM) or a base64-encoded blob (handy for CI secrets).
    is_base64 = !content.include?("BEGIN PRIVATE KEY")
    return app_store_connect_api_key(key_id: key_id, issuer_id: issuer_id,
                                     key_content: content, is_key_content_base64: is_base64,
                                     set_spaceship_token: true, in_house: false)
  end

  key_path = ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"] || locate_key_file(key_id)
  if key_path.nil? || !File.exist?(key_path)
    UI.user_error!("No AuthKey_#{key_id}.p8 found. Set APP_STORE_CONNECT_API_KEY_KEY_FILEPATH " \
                   "or drop it in: #{KEY_SEARCH_DIRS.join(', ')}.")
  end
  app_store_connect_api_key(key_id: key_id, issuer_id: issuer_id, key_filepath: key_path,
                            set_spaceship_token: true, in_house: false)
end

# One-time App Store Connect setup: create the app record for BOTH platforms
# (one multiplatform record, shared bundle id io.river.MeowPassword). Run once:
#   fastlane setup
# Requires the App Store Connect API key env vars (see asc_api_key). The
# extension App IDs (…​.Messages, …​.Share) register automatically at first
# build via -allowProvisioningUpdates.
# Read-only: confirm the API key reaches App Store Connect (reads an existing
# app; creates nothing). Handy before running `setup`.
lane :validate_key do
  api_key = asc_api_key
  num = latest_testflight_build_number(
    api_key: api_key,
    app_identifier: ENV.fetch("VALIDATE_APP_ID", "io.river.clientAPT")
  )
  UI.success("App Store Connect API key works — reached the account (latest TestFlight build: #{num}).")
end

lane :setup do
  asc_api_key   # authenticates spaceship with the API key
  require "spaceship"

  if (existing = Spaceship::ConnectAPI::App.find(APP_ID))
    UI.success("App is on App Store Connect: #{existing.name} (#{APP_ID}). " \
               "Ready — run: fastlane ios beta  and  fastlane mac beta")
    next
  end

  # Apple does NOT allow creating an app record via the App Store Connect API
  # (the `apps` resource is GET/UPDATE only). The bundle id is already
  # registered; create the record once in the web UI, then everything else
  # (builds, TestFlight, metadata) is fully automated with the API key.
  UI.important("The app record must be created once in the App Store Connect web UI:")
  UI.message("  https://appstoreconnect.apple.com  →  Apps  →  +  →  New App")
  UI.message("    Platforms : iOS and macOS (tick both)")
  UI.message("    Name      : #{ENV.fetch('APP_NAME', 'MeowPassword')}")
  UI.message("    Bundle ID : #{APP_ID}   (already registered)")
  UI.message("    SKU       : #{ENV.fetch('APP_SKU', 'meowpassword')}")
  UI.message("Then: fastlane ios beta  and  fastlane mac beta  (both upload with the API key).")
end

platform :ios do
  desc "Run the iOS unit tests (compose/decode round-trip) on a simulator."
  lane :tests do
    ensure_project
    run_tests(
      project: PROJECT,
      scheme: IOS_SCHEME,
      devices: [ENV.fetch("TEST_DEVICE", "iPhone 17")],
      result_bundle: true,
      clean: true
    )
  end

  desc "Run the UI tests. Run once per simulator appearance for light/dark:\n" \
       "  xcrun simctl ui booted appearance light && fastlane ios ui_tests\n" \
       "  xcrun simctl ui booted appearance dark  && fastlane ios ui_tests"
  lane :ui_tests do
    ensure_project
    run_tests(
      project: PROJECT,
      scheme: IOS_SCHEME,
      devices: [ENV.fetch("TEST_DEVICE", "iPhone 17")],
      only_testing: ["MeowPasswordUITests"],
      result_bundle: true
    )
  end

  desc "Build + upload the iOS app to TestFlight."
  lane :beta do
    ensure_project
    api_key = asc_api_key
    build_number = `git rev-list --count HEAD`.strip
    build_app(
      project: PROJECT,
      scheme: IOS_SCHEME,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{DEV_TEAM} CURRENT_PROJECT_VERSION=#{build_number}"
    )
    upload_to_testflight(api_key: api_key, app_identifier: APP_ID,
                         skip_waiting_for_build_processing: true)
  end

  desc "Build + upload the iOS app to App Store review (no auto-submit)."
  lane :release do
    ensure_project
    api_key = asc_api_key
    build_app(
      project: PROJECT,
      scheme: IOS_SCHEME,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{DEV_TEAM}"
    )
    upload_to_app_store(api_key: api_key, app_identifier: APP_ID,
                        skip_metadata: true, skip_screenshots: true,
                        precheck_include_in_app_purchases: false,
                        force: true, submit_for_review: false)
  end
end

platform :mac do
  desc "Run the shared library + core tests via SwiftPM."
  lane :tests do
    Dir.chdir("..") { sh("swift test") }
  end

  desc "Build + upload the macOS app to TestFlight."
  lane :beta do
    ensure_project
    api_key = asc_api_key
    build_number = `git rev-list --count HEAD`.strip
    build_mac_app(
      project: PROJECT,
      scheme: MAC_SCHEME,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{DEV_TEAM} CURRENT_PROJECT_VERSION=#{build_number}"
    )
    # app_platform: "osx" so the uploader picks the .pkg, not a stray iOS .ipa.
    upload_to_testflight(api_key: api_key, app_identifier: APP_ID, app_platform: "osx",
                         pkg: "MeowPassword.pkg",
                         skip_waiting_for_build_processing: true)
  end

  desc "Build the macOS .pkg only (no upload) — validate before running `mac beta`."
  lane :build_only do
    ensure_project
    build_number = `git rev-list --count HEAD`.strip
    build_mac_app(
      project: PROJECT,
      scheme: MAC_SCHEME,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{DEV_TEAM} CURRENT_PROJECT_VERSION=#{build_number}"
    )
    UI.success("Built MeowPassword.pkg (build #{build_number}). Upload with: fastlane mac beta")
  end

  desc "Build + upload the macOS app to App Store review (no auto-submit)."
  lane :release do
    ensure_project
    api_key = asc_api_key
    build_mac_app(
      project: PROJECT,
      scheme: MAC_SCHEME,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{DEV_TEAM}"
    )
    upload_to_app_store(api_key: api_key, app_identifier: APP_ID, platform: "osx",
                        skip_metadata: true, skip_screenshots: true,
                        precheck_include_in_app_purchases: false,
                        force: true, submit_for_review: false)
  end
end
