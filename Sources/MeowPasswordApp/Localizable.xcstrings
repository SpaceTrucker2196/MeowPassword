    "I sent you a MeowGram! 🐱 Drop this PNG into MeowPassword to decode the hidden message. Keep it a PNG — don't screenshot or convert it, or the message is lost.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe dir ein MeowGram geschickt! 🐱 Zieh dieses PNG in MeowPassword, um die versteckte Nachricht zu dekodieren. Lass es ein PNG — kein Screenshot, keine Umwandlung, sonst geht die Nachricht verloren."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "I sent you a MeowGram! 🐱 Drop this PNG into MeowPassword to decode the hidden message. Keep it a PNG — don't screenshot or convert it, or the message is lost."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je vous ai envoyé un MeowGram ! 🐱 Déposez ce PNG dans MeowPassword pour décoder le message caché. Gardez-le en PNG — pas de capture d'écran ni de conversion, sinon le message est perdu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MeowGram を送りました！🐱 この PNG を MeowPassword にドロップすると隠しメッセージをデコードできます。PNG のまま — スクリーンショットや変換をすると、メッセージは失われます。"
          }
        }
      }
    },
