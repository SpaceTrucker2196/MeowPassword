          "stringUnit": {
            "state": "translated",
            "value": "Copied! Paste it as a PNG — image-paste targets may re-encode it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copié ! Collez-le en PNG — les cibles d'image peuvent le réencoder."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コピーしました！PNG として貼り付けてね — 画像貼り付け先では再エンコードされることがあります。"
          }
        }
      }
    },
    "Nothing to paste — copy a MeowGram image or PNG file first.": {
