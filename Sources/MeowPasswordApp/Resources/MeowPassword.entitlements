<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Direct-distribution (Developer ID + notarization) entitlements. -->
    <!-- Hardened Runtime is enforced via codesign --options runtime;      -->
    <!-- these entitlements narrow what the runtime allows.                -->

    <!-- Needed by the CLI's --update flag to hit api.github.com.          -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- "Install Command-Line Tool" writes the bundled meowpass CLI to a  -->
    <!-- user-picked directory (typically /usr/local/bin or ~/bin) via     -->
    <!-- NSSavePanel.                                                      -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Bundled meowpass CLI is launched via Process from the app.        -->
    <!-- Hardened Runtime blocks JIT / unsigned executables loading, but   -->
    <!-- inside-bundle signed helpers are permitted without any exception. -->
</dict>
</plist>
